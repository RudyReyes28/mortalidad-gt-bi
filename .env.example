
# INSTRUCCIONES:
#   1. Copia este archivo y renombralo a .env
#   2. Rellena cada variable con tus credenciales reales
#   3. NUNCA subas el .env a GitHub (ya está en .gitignore)


# Google Drive (Extractor INE)
# Ruta absoluta al JSON de la Service Account de Google Cloud
# Windows : C:\Users\tuUsuario\proyecto\mortalidad-gt.json
# Linux   : /home/usuario/proyecto/mortalidad-gt.json
GDRIVE_CREDENTIALS_PATH=


# AWS (Extractor S3 — Centroamerica) 
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_PREFIX=raw/centroamerica/


# SharePoint (Extractor OMS/MSPAS)
SHAREPOINT_URL=
SHAREPOINT_USER=
SHAREPOINT_PASSWORD=
SHAREPOINT_FOLDER=


#  RDS fuente (Extractor fuente adicional) 
# Formato: postgresql://usuario:password@host:puerto/base_de_datos
RDS_SOURCE_URL=


#  Sandbox destino (PostgreSQL) 
# Local para desarrollo:
#   postgresql://postgres:tuPassword@localhost:5432/mortalidad_sandbox
# RDS en AWS (cuando este configurado):
#   postgresql://usuario:password@<host>.rds.amazonaws.com:5432/mortalidad_sandbox
SANDBOX_DB_URL=
DW_DB_URL=postgresql://user:pass@localhost:5432/mortalidad_dw
# DW en la nube — nuevo (RDS AWS, puede ser la misma instancia que centroamerica)
DW_CLOUD_URL=postgresql://usuario:password@tu-instancia.rds.amazonaws.com:5432/mortalidad_dw